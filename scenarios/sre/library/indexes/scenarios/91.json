{
    "$schema": "https://raw.githubusercontent.com/itbench-hub/ITBench/refs/heads/main/schemas/library/index/scenario.json",
    "alerts": [],
    "category": "sre",
    "complexity": "medium",
    "description": "This scenario simulates a network disconnection or partion between OpenTelemetry Demo `email` and `checkout` services.",
    "disruptions": [
        {
            "injections": [
                {
                    "args": {
                        "kubernetesObject": {
                            "apiVersion": "chaos-mesh.org/v1alpha1",
                            "kind": "Schedule",
                            "metadata": {
                                "name": "fraud-detection-kafka-network-partition",
                                "namespace": "chaos-mesh"
                            }
                        },
                        "scheduleSpec": {
                            "networkChaos": {
                                "action": "partition",
                                "direction": "to",
                                "mode": "all",
                                "selector": {
                                    "labelSelectors": {
                                        "app.kubernetes.io/component": "email"
                                    },
                                    "namespaces": [
                                        "otel-demo"
                                    ]
                                },
                                "target": {
                                    "mode": "all",
                                    "selector": {
                                        "labelSelectors": {
                                            "app.kubernetes.io/component": "checkout"
                                        },
                                        "namespaces": [
                                            "otel-demo"
                                        ]
                                    }
                                }
                            },
                            "type": "NetworkChaos"
                        }
                    },
                    "id": "scheduled-chaos-mesh-experiment"
                }
            ],
            "waitFor": {
                "preInjection": [
                    {
                        "args": {
                            "kubernetesObject": {
                                "apiVersion": "apps/v1",
                                "kind": "Deployment",
                                "metadata": {
                                    "name": "email",
                                    "namespace": "otel-demo"
                                }
                            },
                            "replicas": 2
                        },
                        "id": "scale-kubernetes-workload"
                    }
                ]
            }
        }
    ],
    "environment": {
        "applications": [
            {
                "id": "opentelemetry-demo"
            }
        ]
    },
    "id": 91,
    "index": 91,
    "platforms": [
        "Kubernetes"
    ],
    "solutions": [
        [
            {
                "steps": [
                    {
                        "command": "kubectl -n chaos-mesh annotate schedule fraud-detection-kafka-network-partition experiment.chaos-mesh.org/pause='true'",
                        "text": "Annotate the schedule to pause the active experiment."
                    },
                    {
                        "command": "kubectl -n chaos-mesh get networkchaos --selector='experiment.chaos-mesh.org/pause=true'",
                        "text": "Retrieve the associated experiment managed by the schedule."
                    },
                    {
                        "text": "Delete the retrieved experiement after it has entered the `Paused` state."
                    },
                    {
                        "command": "kubectl -n chaos-mesh delete schedule fraud-detection-kafka-network-partition experiment.chaos-mesh.org/pause='true'",
                        "text": "Delete the schedule."
                    }
                ]
            }
        ]
    ],
    "tags": [
        "Deployment",
        "Performance"
    ]
}
