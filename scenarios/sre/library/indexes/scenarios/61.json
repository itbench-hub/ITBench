{
    "$schema": "https://raw.githubusercontent.com/itbench-hub/ITBench/refs/heads/main/schemas/library/index/scenario.json",
    "alerts": [],
    "category": "sre",
    "complexity": "medium",
    "description": "This scenario simulates network loss between OpenTelemetry Demo `checkout` and `payment` services.",
    "disruptions": [
        {
            "injections": [
                {
                    "args": {
                        "kubernetesObject": {
                            "apiVersion": "chaos-mesh.org/v1alpha1",
                            "kind": "Schedule",
                            "metadata": {
                                "name": "checkout-payment-network-loss",
                                "namespace": "chaos-mesh"
                            }
                        },
                        "scheduleSpec": {
                            "networkChaos": {
                                "action": "loss",
                                "direction": "to",
                                "duration": "55s",
                                "loss": {
                                    "correlation": "0",
                                    "loss": "100"
                                },
                                "mode": "all",
                                "selector": {
                                    "labelSelectors": {
                                        "app.kubernetes.io/component": "checkout"
                                    },
                                    "namespaces": [
                                        "otel-demo"
                                    ]
                                },
                                "target": {
                                    "mode": "all",
                                    "selector": {
                                        "labelSelectors": {
                                            "app.kubernetes.io/component": "payment"
                                        },
                                        "namespaces": [
                                            "otel-demo"
                                        ]
                                    }
                                }
                            },
                            "type": "NetworkChaos"
                        }
                    },
                    "id": "scheduled-chaos-mesh-experiment"
                }
            ]
        }
    ],
    "environment": {
        "applications": [
            {
                "id": "opentelemetry-demo"
            }
        ]
    },
    "id": 61,
    "index": 61,
    "platforms": [
        "Kubernetes"
    ],
    "solutions": [
        [
            {
                "steps": [
                    {
                        "command": "kubectl -n chaos-mesh annotate schedule checkout-payment-network-loss experiment.chaos-mesh.org/pause='true'",
                        "text": "Annotate the schedule to pause the active experiment."
                    },
                    {
                        "command": "kubectl -n chaos-mesh get networkchaos --selector='experiment.chaos-mesh.org/pause=true'",
                        "text": "Retrieve the associated experiment managed by the schedule."
                    },
                    {
                        "text": "Delete the retrieved experiement after it has entered the `Paused` state."
                    },
                    {
                        "command": "kubectl -n chaos-mesh delete schedule checkout-payment-network-loss experiment.chaos-mesh.org/pause='true'",
                        "text": "Delete the schedule."
                    }
                ]
            }
        ]
    ],
    "tags": [
        "Deployment",
        "Performance"
    ]
}
