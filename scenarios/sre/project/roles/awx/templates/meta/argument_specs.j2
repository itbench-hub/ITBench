---
argument_specs:
  main:
    author:
      - Gerard Vanloo
    options:
      awx_cluster:
        options:
          kubeconfig:
            required: true
            type: str
          platform:
            choices:
              - kubernetes
              - openshift
            required: true
            type: str
          provider:
            required: true
            type: str
        required: true
        type: dict
      awx_configuration:
        options:
          agent:
            options:
              configuration:
                required: true
                type: dict
            required: false
            type: dict
          github:
            options:
              agent:
                options:
                  branch:
                    required: true
                    type: str
                  ssh:
                    options:
                      private_key_passphrase:
                        required: true
                        type: str
                      private_key_path:
                        required: true
                        type: str
                    required: false
                    type: dict
                  url:
                    required: true
                    type: str
                required: true
                type: dict
              itbench:
                options:
                  branch:
                    required: true
                    type: str
                  ssh:
                    options:
                      private_key_passphrase:
                        required: true
                        type: str
                      private_key_path:
                        required: true
                        type: str
                    required: false
                    type: dict
                  url:
                    required: true
                    type: str
                required: true
                type: dict
            required: true
            type: dict
          providers:
            options:
              aws:
                options:
                  enabled:
                    default: false
                    required: false
                    type: bool
                required: false
                type: dict
            required: false
            type: dict
          vendors:
            options:
              datadog:
                options:
                  enabled:
                    default: false
                    required: false
                    type: bool
                  manifest_path:
                    required: false
                    type: str
                  secret_name:
                    required: false
                    type: str
                  api_key_name:
                    required: false
                    type: str
                  app_key_name:
                    required: false
                    type: str
                  manifest:
                    required: false
                    type: str
                  api_key:
                    no_log: true
                    required: false
                    type: str
                  app_key:
                    no_log: true
                    required: false
                    type: str
                required: false
                type: dict
              dynatrace:
                options:
                  enabled:
                    default: false
                    required: false
                    type: bool
                  dynakube_path:
                    required: false
                    type: str
                  dynakube_api_version:
                    required: false
                    type: str
                  dynakube:
                    no_log: true
                    required: false
                    type: str
                required: false
                type: dict
            required: false
            type: dict
          scenarios:
            elements: dict
            options:
              id:
                choices:
{% for scenario in scenarios %}
                  - {{ scenario.id }}
{% endfor %}
                required: true
                type: int
            required: true
            type: list
        required: false
        type: dict
      awx_experiments:
        options:
          agent:
            options:
              version:
                required: true
                type: str
            required: false
            type: dict
          runners:
            options:
              kubeconfigs:
                elements: str
                required: true
                type: list
            required: true
            type: dict
          storage:
            options:
              local:
                options:
                  directory:
                    required: true
                    type: str
                required: false
                type: dict
              s3:
                options:
                  bucket:
                    required: true
                    type: str
                  directory:
                    required: false
                    type: str
                  endpoint:
                    required: true
                    type: str
                required: false
                type: dict
            required: false
            type: dict
          trials:
            required: false
            type: int
          workflow:
            choices:
{% for key in awx_workflow_template_suffixes.keys() %}
              - {{ key }}
{% endfor %}
            required: false
            type: str
        required: false
        type: dict
