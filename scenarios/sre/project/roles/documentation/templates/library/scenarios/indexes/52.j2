---
category: sre
complexity: low
description: This scenario simulates OpenTelemetry Demo being unable to scale up with load is surging.
disruptions:
  - injections:
    - args:
        kubernetesObject:
          apiVersion: apps/v1
          kind: Deployment
          metadata:
            name: checkout
            namespace: {{ applications_managers.opentelemetry_demo.kubernetes.namespace }}
      id: insufficient-kubernetes-resource-quota
    - args:
        flag:
          name: loadGeneratorFloodHomepage
          state: "on"
        kubernetesObject:
          apiVersion: v1
          kind: ConfigMap
          metadata:
            name: flagd-config
            namespace: {{ applications_managers.opentelemetry_demo.kubernetes.namespace }}
      id: opentelemetry-demo-feature-flag
    waitFor:
      postInjection:
        - args:
            kubernetesObject:
              apiVersion: apps/v1
              kind: Deployment
              metadata:
                name: flagd
                namespace: {{ applications_managers.opentelemetry_demo.kubernetes.namespace }}
          id: restart-kubernetes-workload
        - args:
            kubernetesObject:
              apiVersion: apps/v1
              kind: Deployment
              metadata:
                name: load-generator
                namespace: {{ applications_managers.opentelemetry_demo.kubernetes.namespace }}
          id: restart-kubernetes-workload
environment:
  applications:
    - args:
        autoscaling:
          kubernetes:
            hpa: true
      id: opentelemetry-demo
id: 52
solutionTemplates:
  - disruptionIndex: 0
    injectionIndex: 0
  - disruptionIndex: 0
    injectionIndex: 1
