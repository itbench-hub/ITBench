        kubernetesObject:
          apiVersion: apps/v1
          kind: Deployment
          metadata:
            name: cart
            namespace: {{ applications_managers.opentelemetry_demo.kubernetes.namespace }}
      id: nonexistent-kubernetes-workload-node
