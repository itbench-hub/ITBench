---
category: sre
complexity: medium
description: This scenario simulates the OpenTelemetry Demo's `checkout` service being unable to start due to an unsupported architecture image, testing Kubernetes rolling update resilience without forced restart.
disruptions:
  - injections:
    - args:
        container:
          name: checkout
        kubernetesObject:
          apiVersion: apps/v1
          kind: Deployment
          metadata:
            name: checkout
            namespace: {{ applications_managers.opentelemetry_demo.kubernetes.namespace }}
      id: unsupported-architecture-kubernetes-workload-container-image
    waitFor:
      postInjection:
        - args:
            kubernetesObject:
              apiVersion: apps/v1
              kind: Deployment
              metadata:
                name: checkout
                namespace: {{ applications_managers.opentelemetry_demo.kubernetes.namespace }}
          id: delete-workload-pods
environment:
  applications:
    - id: opentelemetry-demo
id: 57
solutionTemplates:
  - disruptionIndex: 0
    injectionIndex: 0
