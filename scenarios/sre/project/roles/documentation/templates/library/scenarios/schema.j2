$schema: https://json-schema.org/draft/2020-12/schema
$defs:
  applicationItem:
    type: object
    required:
      - id
    properties:
      id:
        type: string
        enum: {{ documentation_applications.keys() }}
      args:
        type: object
    allOf:
{% for application in documentation_applications.values() %}
      - if:
          properties:
            id:
              const: {{ application.id }}
        then:
          properties:
            args: {{ application.arguments.jsonSchema }}
{% endfor %}
  faultItem:
    type: object
    required:
      - id
    properties:
      id:
        type: string
        enum: {{ documentation_faults.keys() }}
      args:
        type: object
    allOf:
{% for fault in documentation_faults.values() %}
      - if:
          properties:
            id:
              const: {{ fault.id }}
        then:
          properties:
            args: {{ fault.arguments.jsonSchema }}
{% endfor %}
  waiterItem:
    type: object
    required:
      - id
      - args
    properties:
      id:
        type: string
        enum: {{ documentation_waiters.keys() }}
      args:
        type: object
    allOf:
{% for waiter in documentation_waiters.values() %}
      - if:
          properties:
            id:
              const: {{ waiter.id }}
        then:
          properties:
            args: {{ waiter.arguments.jsonSchema }}
{% endfor %}
type: object
required:
  - alerts
  - category
  - complexity
  - disruptions
  - environment
  - id
  - platforms
  - tags
properties:
  alerts:
    type: array
    items:
      type: string
  category:
    type: string
    enum:
      - finops
      - sre
  complexity:
    type: string
    enum:
      - high
      - low
      - medium
  disruptions:
    type: array
    items:
      type: object
      properties:
        injections:
          type: array
          minItems: 1
          items:
            $ref: "#/$defs/faultItem"
        waitFor:
          type: object
          minProperties: 1
          properties:
            preInjection:
              type: array
              minItems: 1
              items:
                $ref: "#/$defs/waiterItem"
            postInjection:
              type: array
              minItems: 1
              items:
                $ref: "#/$defs/waiterItem"
  environment:
    type: object
    required:
      - applications
    properties:
      applications:
        type: array
        minItems: 1
        items:
          $ref: "#/$defs/applicationItem"
  id:
    type: integer
  platforms:
    type: array
    items:
      type: string
  solutions:
    type: array
    items:
      type: array
      items:
        type: object
        required:
          - steps
        properties:
          steps:
            type: array
            items:
              type: object
              required:
                - text
              properties:
                command:
                  type: string
                text:
                  type: string
  tags:
    type: array
    items:
      type: string
