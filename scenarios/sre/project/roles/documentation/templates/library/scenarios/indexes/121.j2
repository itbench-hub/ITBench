---
category: sre
complexity: medium
description: >-
  This scenario simulates node resource exhaustion by injecting excessive resource
  requests into the OpenTelemetry Demo's `product-catalog` service, causing resource
  pressure on the node and affecting co-located workloads.
disruptions:
  - injections:
    - args:
        kubernetesObject:
          apiVersion: apps/v1
          kind: Deployment
          metadata:
            name: product-catalog
            namespace: {{ applications_managers.opentelemetry_demo.kubernetes.namespace }}
      id: node-resource-exhaustion
environment:
  applications:
    - id: opentelemetry-demo
id: 121
solutionTemplates:
  - disruptionIndex: 0
    injectionIndex: 0
