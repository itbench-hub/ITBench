# yaml-language-server: $schema=../../../../../../schemas/json/library/index/scenario.json
---
category: sre
complexity: medium
description: This scenario simulates the OpenTelemetry Demo's `frontend` service being slow to load images.
disruptions:
- injections:
  - args:
      flag:
        name: imageSlowLoad
        state: 10sec
      kubernetesObject:
        apiVersion: v1
        kind: ConfigMap
        metadata:
          name: flagd-config
          namespace: {{ managers["applications"]["opentelemetry_demo"]["kubernetes"]["namespace"] }}
    id: opentelemetry-demo-feature-flag
  waitFor:
    postInjection:
    - args:
        kubernetesObject:
          apiVersion: apps/v1
          kind: Deployment
          metadata:
            name: flagd
            namespace: {{ managers["applications"]["opentelemetry_demo"]["kubernetes"]["namespace"] }}
      id: restart-kubernetes-workload
    - args:
        kubernetesObject:
          apiVersion: apps/v1
          kind: Deployment
          metadata:
            name: frontend
            namespace: {{ managers["applications"]["opentelemetry_demo"]["kubernetes"]["namespace"] }}
      id: restart-kubernetes-workload
environment:
  applications:
  - id: opentelemetry-demo
    args:
      loadGeneration:
        browserTraffic: true
id: 10
solutionTemplates:
- disruptionIndex: 0
  injectionIndex: 0
