# yaml-language-server: $schema=../../../../../../schemas/json/library/index/scenario.json
---
category: sre
complexity: low
description: This scenario simulates Kubernetes API server experiencing latency during OpenTelemetry Demo's execution.
disruptions:
- injections:
  - args:
      kubernetesObject:
        apiVersion: chaos-mesh.org/v1alpha1
        kind: Schedule
        metadata:
          name: api-server-memory-stress
          namespace: {{ managers["tools"]["chaos_mesh"]["kubernetes"]["namespace"] }}
      scheduleSpec:
        ioChaos:
          action: latency
          delay: 200ms
          duration: 5m
          mode: all
          percent: 50
          selector:
            labelSelectors:
              component: etcd
            namespaces:
            - kube-system
          volumePath: /var/lib/etcd
        type: IOChaos
    id: scheduled-chaos-mesh-experiment
environment:
  applications:
  - id: opentelemetry-demo
id: 55
solutionTemplates:
- disruptionIndex: 0
  injectionIndex: 0
