# yaml-language-server: $schema=../../../../../../schemas/json/library/index/scenario.json
---
category: sre
complexity: medium
description: This scenario simulates OpenTelemetry Demo's `recommendation` service experiencing cpu stress.
disruptions:
- injections:
  - args:
      kubernetesObject:
        apiVersion: chaos-mesh.org/v1alpha1
        kind: Schedule
        metadata:
          name: recommendation-cpu-stress
          namespace: chaos-mesh
      scheduleSpec:
        stressChaos:
          duration: 55s
          mode: all
          selector:
            labelSelectors:
              app.kubernetes.io/component: recommendation
            namespaces:
            - {{ managers["applications"]["opentelemetry_demo"]["kubernetes"]["namespace"] }}
          stressors:
            cpu:
              load: 100
              workers: 30
        type: StressChaos
    id: scheduled-chaos-mesh-experiment
environment:
  applications:
  - id: opentelemetry-demo
id: 25
solutionTemplates:
- disruptionIndex: 0
  injectionIndex: 0
