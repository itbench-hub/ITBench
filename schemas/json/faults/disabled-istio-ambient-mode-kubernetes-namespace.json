{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "kubernetesObject": {
            "properties": {
                "apiVersion": {
                    "enum": [
                        "v1"
                    ],
                    "type": "string"
                },
                "kind": {
                    "enum": [
                        "Namespace"
                    ],
                    "type": "string"
                },
                "metadata": {
                    "properties": {
                        "name": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "name"
                    ],
                    "type": "object"
                }
            },
            "required": [
                "apiVersion",
                "kind",
                "metadata"
            ],
            "type": "object"
        }
    },
    "required": [
        "kubernetesObject"
    ],
    "type": "object"
}
