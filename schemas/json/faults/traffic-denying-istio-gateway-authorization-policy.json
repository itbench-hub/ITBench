{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "httpMethods": {
            "items": {
                "enum": [
                    "GET",
                    "POST",
                    "DELETE",
                    "PUT"
                ],
                "type": "string"
            },
            "type": "array"
        },
        "kubernetesObject": {
            "properties": {
                "apiVersion": {
                    "enum": [
                        "gateway.networking.k8s.io/v1"
                    ],
                    "type": "string"
                },
                "kind": {
                    "enum": [
                        "Gateway"
                    ],
                    "type": "string"
                },
                "metadata": {
                    "properties": {
                        "name": {
                            "type": "string"
                        },
                        "namespace": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "name",
                        "namespace"
                    ],
                    "type": "object"
                }
            },
            "required": [
                "apiVersion",
                "kind",
                "metadata"
            ],
            "type": "object"
        }
    },
    "required": [
        "httpMethods",
        "kubernetesObject"
    ],
    "type": "object"
}
