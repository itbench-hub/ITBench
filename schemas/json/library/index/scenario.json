        "id": {
            "type": "integer"
        },
        "platforms": {
            "items": {
                "type": "string"
            },
            "type": "array"
        },
        "solutions": {
            "items": {
                "items": {
                    "properties": {
                        "steps": {
                            "items": {
                                "properties": {
                                    "command": {
                                        "type": "string"
                                    },
                                    "text": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "text"
                                ],
                                "type": "object"
                            },
                            "type": "array"
                        }
                    },
                    "required": [
                        "steps"
                    ],
                    "type": "object"
                },
                "type": "array"
            },
            "type": "array"
        },
        "tags": {
