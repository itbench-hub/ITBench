                "sre"
            ],
            "type": "string"
        },
        "complexity": {
            "enum": [
                "high",
                "low",
                "medium"
            ],
            "type": "string"
        },
        "disruptions": {
            "items": {
                "properties": {
                    "injections": {
                        "items": {
                            "$ref": "#/$defs/faultItem"
                        },
                        "minItems": 1,
                        "type": "array"
                    },
                    "waitFor": {
                        "minProperties": 1,
                        "properties": {
                            "postInjection": {
                                "items": {
                                    "$ref": "#/$defs/waiterItem"
                                },
                                "minItems": 1,
                                "type": "array"
                            },
                            "preInjection": {
                                "items": {
                                    "$ref": "#/$defs/waiterItem"
                                },
                                "minItems": 1,
                                "type": "array"
                            }
                        },
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "type": "array"
        },
        "environment": {
            "properties": {
                "applications": {
                    "items": {
                        "$ref": "#/$defs/applicationItem"
                    },
                    "minItems": 1,
                    "type": "array"
                }
